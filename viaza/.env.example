# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Requerida para: Translator (gpt-4.1-mini), OCR boarding pass (gpt-4o),
#                 Asistente de acomodo de maleta (gpt-4o vision)
VITE_OPENAI_API_KEY=your-openai-api-key

# ─── OpenWeatherMap ───────────────────────────────────────────────────────────
# Requerida para: Condiciones actuales del clima en el dashboard
# Gratis hasta 1,000 llamadas/día: https://openweathermap.org/api
# Si no se configura, el pronóstico usa solo Open-Meteo (sin condiciones actuales)
VITE_OPENWEATHERMAP_KEY=your-openweathermap-api-key

# ─── AviationStack ───────────────────────────────────────────────────────────
# Requerida para: Búsqueda de vuelos en tiempo real (AirlineRulesPage)
# Gratis hasta 500 llamadas/mes: https://aviationstack.com
# Si no se configura, el módulo funciona en modo manual (datos del onboarding)
VITE_AVIATIONSTACK_KEY=your-aviationstack-api-key

# ─── Google Maps ─────────────────────────────────────────────────────────────
# Requerida para: Mapas estáticos en tarjetas de destino (thumbnails)
# Los deep links de navegación (Waze, Google Maps, Apple Maps) funcionan SIN key
# https://developers.google.com/maps/documentation/maps-static
VITE_GOOGLE_MAPS_KEY=your-google-maps-api-key

# ─── Supabase (opcional — para auth y persistencia en la nube) ───────────────
# Si no se configura, la app usa almacenamiento local (Capacitor Preferences)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key